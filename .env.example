# ClaudiaClaw Configuration
# Copy ke .env dan isi nilainya

DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-v4-flash
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Webhook (production) — set URL to enable webhook mode
# Jika kosong, akan menggunakan long-polling (development)
TELEGRAM_WEBHOOK_URL=https://your-domain.com
TELEGRAM_WEBHOOK_PORT=8443

# Allowlist — biarkan kosong untuk allow all
# ALLOWLIST_USERS=659617669,1714557404
# ALLOWLIST_GROUPS=-1003953147640
# ALLOWLIST_OWNERS=659617669

MAX_HISTORY=50
