{
  "name": "claudiaclaw",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "description": "Super modern, efficient & effective agent framework \u2014 built from scratch with DeepSeek",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "clean": "rm -rf packages/*/dist node_modules/.cache",
    "dev": "npm run dev --workspaces --if-present",
    "start": "node ./packages/cli/dist/index.js start",
    "init": "node ./packages/cli/dist/index.js init",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint packages/*/src --ext .ts",
    "format": "prettier --write 'packages/*/src/**/*.ts'",
    "fresh": "rm -rf packages/*/dist .env config.json data node_modules && npm install && npm run build"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "tsup": "^8.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}